{
  "name": "create-stk-repo",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel --filter=./apps/* --filter=!./apps/cli",
    "cli:dev": "turbo run cli:dev --filter=./apps/cli",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "ci": "turbo run lint && turbo run test && turbo run build",
    "release": "turbo run lint test build",
    "publish": "npm publish --workspace create-stk --access public"
  },
  "trustedDependencies": [
    "esbuild"
  ],
  "overrides": {
    "picomatch": "4.0.4",
    "postcss": "8.5.15",
    "rollup": "4.60.4",
    "vite": "8.0.14"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "turbo": "^2.9.14"
  }
}
