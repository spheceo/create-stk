{
  "name": "create-stk",
  "version": "0.1.2",
  "description": "Opinionated, unified project scaffolding CLI.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "create-stk": "dist/index.js"
  },
  "scripts": {
    "cli:dev": "tsx src/index.ts",
    "test": "vitest run",
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "lint": "tsc",
    "ci": "bun run lint && bun run test && bun run build",
    "release": "bun run lint && bun run test && bun run build && changeset publish",
    "prepare": "bun run build"
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "keywords": [
    "scaffold",
    "cli"
  ],
  "author": "Sphe",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "giget": "^3.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
